{
  "name": "solana-agent-website-api",
  "version": "1.0.0",
  "description": "Solana Agent website HTTP API (reserves, swap, treasury, Orca proxy, Clawstr, bulletin, analytics)",
  "type": "commonjs",
  "main": "api-server.cjs",
  "scripts": {
    "start": "node api-server.cjs",
    "test": "node test-api-no-tx.js && node test-pages.js",
    "test:treasury-usdt": "node test/treasury-usdt-to-usdc-local.cjs",
    "test:treasury-usdt:lifi": "node test/treasury-usdt-to-usdc-local.cjs --lifi",
    "test:api": "node test-api-no-tx.js",
    "test:pages": "node test-pages.js",
    "test:swap": "node test-swap-sol-to-btc.js",
    "test:lifi": "node test-lifi-sol-to-btc.js",
    "treasury:swap-usdt-usdc": "node scripts/run-treasury-usdt-to-usdc.cjs",
    "treasury:swap-usdt-jupiter": "node scripts/run-treasury-usdt-to-usdc-jupiter.cjs",
    "treasury:swap-usdc-jupiter": "node scripts/run-treasury-usdc-to-usdt-jupiter.cjs",
    "treasury:receive": "node scripts/receive-stable-to-treasury.cjs",
    "treasury:receive-reward": "node scripts/receive-confirm-and-reward.cjs",
    "mint:token": "node scripts/mint-token-human.cjs",
    "treasury:mint-scheduled": "node scripts/mint-treasury-sabtc-saeth-scheduled.cjs",
    "mcp": "node mcp-server.cjs",
    "clawstr:generate-account": "node clawstr/scripts/generate-account.cjs",
    "clawstr:spike-publish": "node clawstr/scripts/spike-publish.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.4",
    "better-sqlite3": "^12.8.0",
    "bitcoinjs-lib": "^5.2.0",
    "bitcoinjs-message": "^2.2.0",
    "bs58": "^6.0.0",
    "nostr-tools": "1.17.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  }
}
